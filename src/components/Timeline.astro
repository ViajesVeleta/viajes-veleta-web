---
interface Props {
    mode?: 'left' | 'alternate';
}

const { mode = 'left' } = Astro.props;
---

<div class={`timeline-wrapper mode-${mode}`}>
    <div class="timeline-container">
        <div class="timeline-gradient-line"></div>
        <div class="timeline-content-area">
            <slot />
        </div>
    </div>
</div>

<style>
    .timeline-wrapper {
        width: 100%;
        max-width: none;
        margin: 4rem 0;
        padding: 0;
    }

    .timeline-container {
        position: relative;
    }

    /* mode-left (Default) */
    .mode-left .timeline-container {
        padding-left: 40px;
    }
    .mode-left .timeline-gradient-line {
        left: 20px;
    }

    /* mode-alternate */
    @media (min-width: 1025px) {
        .mode-alternate .timeline-container {
            padding-left: 0;
        }
        .mode-alternate .timeline-gradient-line {
            left: 50%;
        }
        .mode-alternate .timeline-content-area {
            display: block; /* Use block for floating children */
            gap: 0;
        }
        /* Clearfix for floating items */
        .mode-alternate .timeline-content-area::after {
            content: "";
            display: table;
            clear: both;
        }
    }

    /* mobile/tablet behavior - always left mode below desktop */
    @media (max-width: 1024px) {
        .timeline-container {
            padding-left: 40px !important;
        }
        .timeline-gradient-line {
            left: 20px !important;
        }
    }

    .timeline-gradient-line {
        position: absolute;
        transform: translateX(-50%);
        top: 5px;
        bottom: -20px;
        width: 4px;
        background: linear-gradient(
            to bottom,
            var(--primary) 0%,
            color-mix(in srgb, var(--primary), transparent 60%) 70%,
            transparent 100%
        );
        border-radius: 4px;
        opacity: 0.5;
        z-index: 1;
    }

    .timeline-content-area {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    @media (max-width: 640px) {
        .timeline-wrapper {
            padding: 0;
        }
    }
</style>
