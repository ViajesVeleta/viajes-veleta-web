---
/**
 * Gallery Component
 * Handles a grid of images and a full-screen lightbox dialog.
 */
import { Image } from "astro:assets";
import { getDynamicImage } from "../utils/images";

interface Props {
  images: string[]; // List of image paths (e.g., ["assets/...", "assets/..."])
  cols?: number;    // e.g., 3
}

const { images: imagePaths, cols = 3 } = Astro.props;

const galleryImages = [];
for (const path of imagePaths) {
  const meta = getDynamicImage(path);
  if (meta) {
    galleryImages.push(meta);
  }
}

// Prepare images for client-side JS (these are processed URLs)
const imageUrls = JSON.stringify(galleryImages.map(img => img.src));
---

<div class="gallery-container" data-gallery-images={imageUrls}>
  <div class="gallery-grid" style={`grid-template-columns: repeat(${cols}, 1fr);`}>
    {galleryImages.map((img, idx) => (
    
      <a 
        href="#" 
        class="gallery-item-link"
        data-idx={idx}
      >
        <Image 
          src={img} 
          alt={`Galería ${idx + 1}`} 
          class="gallery-thumb"
          draggable="false"
        />
      </a>
    ))}
  </div>
  <dialog class="gallery-dialog">
    <div class="dialog-overlay">
      <div class="dialog-image-container">
        <button type="button" class="dialog-close" aria-label="Cerrar galería">
          <i class="fa-solid fa-xmark"></i>
        </button>
        
        <img class="gallery-dialog-img" src="" alt="Imagen ampliada de la galería" draggable="false" />
        
        <div class="dialog-controls">
          <button type="button" class="dialog-prev" aria-label="Imagen anterior">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          
          <div class="dialog-info">
            <span class="gallery-dialog-count"></span>
          </div>
          
          <button type="button" class="dialog-next" aria-label="Imagen siguiente">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
        </div>
      </div>
    </div>
  </dialog>
</div>

<script is:inline>
  // Use event delegation for all galleries
  document.addEventListener('click', function(e) {
    // Handle gallery item clicks
    const link = e.target.closest('.gallery-item-link');
    if (link) {
      e.preventDefault();
      const idx = parseInt(link.dataset.idx || '0', 10);
      const container = link.closest('.gallery-container');
      if (!container) return;
      
      const dialog = container.querySelector('.gallery-dialog');
      const imgElement = container.querySelector('.gallery-dialog-img');
      const countElement = container.querySelector('.gallery-dialog-count');
      
      if (!dialog || !imgElement) return;
      
      // Get image URLs for this specific gallery
      const imgs = JSON.parse(container.dataset.galleryImages || '[]');
      
      // Initial set
      imgElement.src = imgs[idx];
      imgElement.classList.remove('transitioning');
      imgElement.classList.add('fade-in');
      
      dialog.showModal();
      document.body.style.overflow = 'hidden';
      dialog.classList.remove('dialog-closing');
      dialog.dataset.index = idx;
      
      // Update count
      if (countElement) {
        countElement.textContent = (idx + 1) + ' de ' + imgs.length;
      }
    }
    
    // Handle close button
    const closeBtn = e.target.closest('.dialog-close');
    if (closeBtn) {
      e.stopPropagation();
      const dialog = closeBtn.closest('.gallery-dialog');
      if (dialog) {
        dialog.classList.add('dialog-closing');
        document.body.style.overflow = '';
        setTimeout(() => {
          dialog.close();
          dialog.classList.remove('dialog-closing');
        }, 300);
      }
    }
    
    // Handle prev button
    const prevBtn = e.target.closest('.dialog-prev');
    if (prevBtn) {
      e.stopPropagation();
      const dialog = prevBtn.closest('.gallery-dialog');
      const container = dialog?.closest('.gallery-container');
      if (!dialog || !container) return;
      
      const imgs = JSON.parse(container.dataset.galleryImages || '[]');
      let idx = parseInt(dialog.dataset.index || '0', 10);
      idx = (idx - 1 + imgs.length) % imgs.length;
      
      updateDialogImg(dialog, container, imgs, idx);
    }
    
    // Handle next button
    const nextBtn = e.target.closest('.dialog-next');
    if (nextBtn) {
      e.stopPropagation();
      const dialog = nextBtn.closest('.gallery-dialog');
      const container = dialog?.closest('.gallery-container');
      if (!dialog || !container) return;
      
      const imgs = JSON.parse(container.dataset.galleryImages || '[]');
      let idx = parseInt(dialog.dataset.index || '0', 10);
      idx = (idx + 1) % imgs.length;
      
      updateDialogImg(dialog, container, imgs, idx);
    }
    
    // Handle click outside to close
    if (e.target.classList.contains('dialog-overlay')) {
      const dialog = e.target.closest('.gallery-dialog');
      if (dialog) {
        dialog.classList.add('dialog-closing');
        document.body.style.overflow = '';
        setTimeout(() => {
          dialog.close();
          dialog.classList.remove('dialog-closing');
        }, 300);
      }
    }
  });
  
  // Handle Escape key
  document.addEventListener('cancel', function(e) {
    const dialog = e.target.closest('.gallery-dialog');
    if (dialog) {
      e.preventDefault();
      dialog.classList.add('dialog-closing');
      document.body.style.overflow = '';
      setTimeout(() => {
        dialog.close();
        dialog.classList.remove('dialog-closing');
      }, 300);
    }
  }, true); // Use capture to catch the event
  
  function updateDialogImg(dialog, container, imgs, idx) {
    const imgElement = container.querySelector('.gallery-dialog-img');
    const countElement = container.querySelector('.gallery-dialog-count');
    
    if (!imgElement) return;
    
    // Switch animation: fade out, change image, fade in
    imgElement.classList.remove('fade-in');
    imgElement.classList.add('transitioning');
    
    setTimeout(() => {
      dialog.dataset.index = idx;
      imgElement.src = imgs[idx];
      
      if (countElement) {
        countElement.textContent = (idx + 1) + ' de ' + imgs.length;
      }
      
      // Allow browser to process src change before fading back in
      imgElement.onload = () => {
        imgElement.classList.remove('transitioning');
        imgElement.classList.add('fade-in');
      };
      
      // Fallback if onload doesn't fire (e.g. cached)
      setTimeout(() => {
        if (imgElement.classList.contains('transitioning')) {
          imgElement.classList.remove('transitioning');
          imgElement.classList.add('fade-in');
        }
      }, 300);
      
    }, 150);
  }
</script>

<style>
  .gallery-grid {
    display: grid;
    gap: 0;
    margin: 1.5rem 0;
  }
  
  .gallery-item-link {
    display: block;
    aspect-ratio: 1/1;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }
  
  .gallery-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .gallery-item-link:hover .gallery-thumb {
    transform: scale(1.08);
  }
  
  /* --- LIGHTBOX ANIMATIONS --- */
   
  .gallery-dialog {
    padding: 0;
    border: none;
    background: transparent;
    width: 100vw;
    max-width: 100vw;
    height: 100vh;
    max-height: 100vh;
    overflow: hidden;
    color: white;
    
    /* Unified transition for all states */
    opacity: 0;
    transform: scale(0.95);
    transition: 
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), 
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      display 0.3s cubic-bezier(0.4, 0, 0.2, 1) allow-discrete, 
      overlay 0.3s cubic-bezier(0.4, 0, 0.2, 1) allow-discrete;
  }
  
  /* When open, go to full visibility */
  .gallery-dialog[open] {
    opacity: 1;
    transform: scale(1);
  }
  
  /* Starting styles for the entry transition */
  @starting-style {
    .gallery-dialog[open] {
      opacity: 0;
      transform: scale(0.95);
    }
    .gallery-dialog[open]::backdrop {
      background: rgba(0, 0, 0, 0);
      backdrop-filter: blur(0px);
    }
  }
  
  /* Backdrop logic */
  .gallery-dialog::backdrop {
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    transition: 
      background 0.3s ease, 
      backdrop-filter 0.3s ease, 
      display 0.3s allow-discrete, 
      overlay 0.3s allow-discrete;
  }
  
  .gallery-dialog[open]::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(12px);
  }
  
  /* Specific class for closing phase via JS */
  .gallery-dialog.dialog-closing {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }
  
  .gallery-dialog.dialog-closing::backdrop {
    background: rgba(0, 0, 0, 0) !important;
    backdrop-filter: blur(0px) !important;
  }
  
  
  
  /* Image Crossfade */
  .gallery-dialog-img {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    border-radius: 4px;
    background: #000;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
    transform: scale(0.98);
  }
  
  .gallery-dialog-img.fade-in {
    opacity: 1;
    transform: scale(1);
  }
  
  .gallery-dialog-img.transitioning {
    opacity: 0;
    transform: scale(1.02);
  }
  
  .dialog-overlay {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    cursor: default;
  }
  
  
  .dialog-image-container {
    position: relative;
    max-width: min(95vw, 1400px);
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: default;
    background: rgba(0,0,0,0.4);
    padding: 12px;
    border-radius: 12px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    border: 1px solid rgba(255,255,255,0.05);
  }
  
  .dialog-close {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 20;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0;
    line-height: 1;
  }
  
  .dialog-close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: rotate(90deg) scale(1.1);
    border-color: rgba(255,255,255,0.3);
  }
  
  .dialog-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 16px;
    width: 100%;
  }
  
  .dialog-prev, .dialog-next {
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    flex-shrink: 0;
    padding: 0;
    line-height: 1;
  }
  
  .dialog-prev:hover, .dialog-next:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
    border-color: rgba(255,255,255,0.3);
  }
  
  .dialog-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    letter-spacing: 0.05em;
    min-width: 150px;
    text-align: center;
  }
  
  .gallery-dialog-count {
    font-size: 0.95rem;
    opacity: 0.9;
  }
  
  
  @media (max-width: 768px) {
    .dialog-close {
      top: -10px;
      right: -10px;
    }
    .dialog-controls {
      gap: 12px;
    }
    .dialog-prev, .dialog-next {
      width: 40px;
      height: 40px;
    }
  }
</style>
