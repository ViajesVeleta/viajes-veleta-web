---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

// Get current year for copyright
const currentYear = new Date().getFullYear();

// Get upcoming trip
const allGroups = await getCollection("groups", ({ id }) => {
    return id.startsWith(`${lang}/`);
});

const sortedGroups = allGroups.sort(
    (a, b) => a.data.date.valueOf() - b.data.date.valueOf(),
);

const today = new Date();
const upcomingTrips = sortedGroups.filter((trip) => trip.data.date >= today);
let nextTrips = upcomingTrips.slice(0, 2);
if (nextTrips.length === 0) {
    nextTrips = sortedGroups.slice(-2).reverse();
}
---

<footer transition:persist>
	<!-- Upper Footer -->
	<div class="footer-upper">
		<div class="footer-container">
			<div class="footer-section">
				<h3>¡Síguenos!</h3>
				<div class="social-links">
					<a
						href="https://www.facebook.com/people/Viajes-Veleta/61564838170871/"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Síguenos en Facebook"
						class="facebook-link"
					>
						<i class="fa-brands fa-facebook-f"></i>
					</a>
					<a
						href="https://instagram.com/viajesveletaguadix"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Síguenos en Instagram"
						class="instagram-link"
					>
						<i class="fa-brands fa-instagram"></i>
					</a>
				</div>
				<p class="cif">CIF: B18802645</p>
			</div>

			<div class="footer-section">
				<h3>{lang === "es" ? "Próximos viajes" : "Upcoming Trips"}</h3>
				<div class="next-trips-container">
					{nextTrips.map((trip) => (
						<a href={`/${lang === "es" ? "" : "en/"}viajes-en-grupo/${trip.id.split("/").slice(1).join("/")}/`} class="next-trip-card">
							{trip.data.image && (
								<Image
									src={trip.data.image}
									alt={trip.data.title}
									width={400}
									height={300}
									class="next-trip-img"
								/>
							)}
							<span class="next-trip-title">{trip.data.title}</span>
						</a>
					))}
				</div>
			</div>
		</div>
	</div>

	<!-- Lower Footer -->
	<div class="footer-lower">
		<div class="footer-container">
			<p class="copyright">&copy; Viajes Veleta {currentYear}</p>
			<nav class="footer-links">
				<a href="/condiciones-generales">Condiciones generales</a>
				<a href="/contrato-viaje-combinado"
					>Contrato de viaje combinado</a
				>
				<a href="/politica-privacidad">Política de privacidad</a>
			</nav>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: auto;
	}

	.footer-upper {
		background-color: #1a1a1a;
		color: #ffffff;
		padding: 3rem 1.5rem;
	}

	.footer-lower {
		background-color: #000000;
		color: #ffffff;
		padding: 1.5rem 1.5rem;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-evenly;
		align-items: flex-start;
		gap: 3rem;
		flex-wrap: wrap;
	}

	.footer-lower .footer-container {
		align-items: center;
		gap: 2rem;
	}

	.footer-section {
		min-width: 250px;
	}

	.footer-section h3 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
		font-weight: 600;
		color: #ffffff;
	}

	.social-links {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 64px;
		height: 64px;
		border-radius: 50%;
		text-decoration: none;
		color: #ffffff;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease;
	}

	.social-links a.facebook-link {
		background-color: #0866FF; /* Modern Facebook blue */
	}

	.social-links a.instagram-link {
		background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
	}

	.social-links a:hover {
		transform: scale(1.1);
		opacity: 0.9;
	}

	.social-links i {
		font-size: 2rem;
	}

	.cif {
		font-size: 0.95rem;
		margin: 0;
		color: #ffffff;
	}

	.next-trips-container {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		max-width: 450px;
	}

	.next-trip-card {
		display: block;
		text-decoration: none;
		border-radius: 16px;
		overflow: hidden;
		position: relative;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		width: 100%;
		box-shadow: 0 2px 8px rgba(255, 255, 255, 0.05);
	}

	.next-trip-card:hover {
		transform: scale(1.03);
		box-shadow: 0 4px 12px rgba(255, 255, 255, 0.1);
	}

	.next-trip-img {
		width: 100%;
		height: auto;
		aspect-ratio: 4/3;
		object-fit: cover;
		display: block;
	}

	.next-trip-title {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 60%, transparent 100%);
		color: #ffffff;
		padding: 2rem 0.5rem 0.5rem;
		font-size: 0.85rem;
		font-weight: 600;
		text-align: center;
		text-shadow: 0 1px 2px rgba(0,0,0,0.8);
		line-height: 1.2;
	}

	.copyright {
		margin: 0;
		font-size: 0.95rem;
	}

	.footer-links {
		display: flex;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.footer-links a {
		color: #ffffff;
		text-decoration: none;
		font-size: 0.9rem;
		transition: opacity 0.2s ease;
		opacity: 0.85;
	}

	.footer-links a:hover {
		opacity: 1;
		text-decoration: underline;
	}

	/* Mobile responsive */
	@media (max-width: 768px) {
		.footer-container {
			flex-direction: column;
			gap: 2rem;
		}

		.footer-lower .footer-container {
			flex-direction: column;
			text-align: center;
			gap: 1rem;
		}

		.footer-section {
			min-width: 100%;
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.footer-section h3 {
			text-align: center;
			width: 100%;
		}

		.next-trips-container {
			margin: 0 auto;
			width: 100%;
			justify-content: center;
		}

		.social-links {
			justify-content: center;
		}

		.footer-links {
			flex-direction: column;
			gap: 0.75rem;
			align-items: center;
		}
	}
</style>
