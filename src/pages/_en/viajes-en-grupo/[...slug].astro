---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../../layouts/BlogPost.astro";
import Timeline from "../../../components/Timeline.astro";
import TimelineItem from "../../../components/TimelineItem.astro";
import PricingGrid from "../../../components/PricingGrid.astro";
import PricingItem from "../../../components/PricingItem.astro";
import IncludeExclude from "../../../components/IncludeExclude.astro";
import FlightGrid from "../../../components/FlightGrid.astro";
import FlightItem from "../../../components/FlightItem.astro";
import Columns from "../../../components/Columns.astro";
import ColumnItem from "../../../components/ColumnItem.astro";
import Button from "../../../components/Button.astro";
import Gallery from "../../../components/Gallery.astro";


export async function getStaticPaths() {
    const allPosts = await getCollection("groups");
    
    // Group by logical content ID (defined in frontmatter)
    const grouped = allPosts.reduce((acc, post) => {
        const id = post.data.id;
        if (!id) return acc;
        if (!acc[id]) acc[id] = {};
        const [lang] = post.id.split("/");
        acc[id][lang] = post;
        return acc;
    }, {} as Record<string, Record<string, CollectionEntry<"groups">>>);

    return Object.entries(grouped).map(([id, translations]) => {
        // Preference for English version, fallback to Spanish
        const post = translations.en || translations.es;
        
        // Extract slug from filename (always use filenames as slugs)
        const [_, ...idParts] = post.id.split("/");
        const slug = idParts.join("/");
        
        return {
            params: { slug },
            props: post,
        };
    });
}

type Props = CollectionEntry<"groups">;

const post = Astro.props;
const { Content } = await render(post);
const components = { Gallery, Timeline, TimelineItem, PricingGrid, PricingItem, IncludeExclude, FlightGrid, FlightItem, Columns, ColumnItem, Button };

// Find translations
const allPosts = await getCollection("groups");
const translations = allPosts.filter(
    (p) => p.data.id === post.data.id && post.data.id !== undefined,
);
const translatedPaths: Record<string, string> = {};
translations.forEach((p) => {
    const [pLang, ...idParts] = p.id.split("/");
    const pSlug = idParts.join("/");
    translatedPaths[pLang] =
        pLang === "es"
            ? `/viajes-en-grupo/${pSlug}/`
            : `/en/viajes-en-grupo/${pSlug}/`;
});
---

<BlogPost {...post.data} translatedPaths={translatedPaths} id={post.id} collection={post.collection}>
    <Content components={components} />
</BlogPost>
