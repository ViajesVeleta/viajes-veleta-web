---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContentFallback from "../components/ContentFallback.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const translatedPaths = {
    es: "/contacto",
    en: "/en/contacto",
};

const urlParams = Astro.url.searchParams;
const isFallback = urlParams.get("lang") === "en";
---

<!doctype html>
<html lang={lang}>
    <head>
        <BaseHead
            title={`${t("nav.contact")} - ${SITE_TITLE}`}
            description="Contacta con Viajes Veleta en Guadix. Estamos aquí para organizar tu próxima gran aventura, viaje en grupo o escapada a medida. Llámanos o ven a vernos."
            translatedPaths={translatedPaths}
        />
        <style>
            :root {
                --contact-bg: #f5f6f8;
                --contact-text: #111;
                --contact-light: #555;
            }
            body {
                background-color: var(--contact-bg);
                color: var(--contact-text);
            }
            main {
                width: 100%;
                max-width: 1200px;
                margin: 0 auto;
                padding: 0 1.5rem 6rem;
                overflow: hidden;
            }

            /* --- HERO SECTION --- */
            .contact-hero {
                display: flex;
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
                padding-top: 200px; /* space for transparent header */
                padding-bottom: 8rem;
                position: relative;
            }
            
            .hero-vertical-text {
                position: absolute;
                left: 35%;
                transform: translateX(-50%) rotate(90deg);
                top: 15%;
                font-size: 8rem;
                font-weight: 800;
                color: rgba(200, 205, 210, 0.3); /* faint gray */
                z-index: -1;
                letter-spacing: 0.05em;
                transform-origin: left top;
                pointer-events: none;
            }

            .hero-text {
                flex: 1;
                max-width: 450px;
                z-index: 2;
            }
            .hero-text h1 {
                font-size: 4rem;
                font-weight: 700;
                margin: 0 0 1rem 0;
                line-height: 1.1;
                color: var(--contact-text);
            }
            .hero-text p {
                font-size: 1.1rem;
                color: var(--contact-light);
                font-weight: 500;
                line-height: 1.6;
            }

            .hero-images {
                flex: 1;
                display: flex;
                position: relative;
                height: 500px;
                width: 100%;
                max-width: 600px;
            }
            .hero-img {
                position: absolute;
                border-radius: 2rem;
                box-shadow: 0 25px 50px rgba(0,0,0,0.1);
                object-fit: cover;
            }
            .hero-img-1 {
                width: 55%;
                height: 70%;
                bottom: 0;
                left: 0;
                z-index: 2;
            }
            .hero-img-2 {
                width: 55%;
                height: 80%;
                top: 0;
                right: 5%;
                z-index: 1;
            }

            /* --- ICONS SECTION --- */
            .icon-grid-section {
                text-align: center;
                padding: 4rem 0 8rem;
            }
            .icon-grid-section h2 {
                font-size: 2.2rem;
                font-weight: 500;
                margin-bottom: 6rem;
            }

            .contact-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 4rem 2rem;
                max-width: 1000px;
                margin: 0 auto;
            }

            .contact-item {
                display: flex;
                flex-direction: column;
                align-items: center;
                text-decoration: none;
                color: var(--contact-text);
                transition: transform 0.3s ease;
            }
            .contact-item:hover {
                transform: translateY(-5px);
            }

            .icon-circle {
                width: 80px;
                height: 80px;
                background-color: var(--contact-text);
                color: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2rem;
                margin-bottom: 2rem;
                box-shadow: 0 15px 30px rgba(0,0,0,0.1);
                transition: background-color 0.3s ease;
            }
            
            .contact-item:hover .icon-circle {
                background-color: var(--accent, #0056b3);
            }

            .contact-item h3 {
                font-size: 1.1rem;
                margin: 0 0 0.5rem 0;
                font-weight: 600;
            }
            .contact-item p {
                font-size: 0.95rem;
                margin: 0;
                color: var(--contact-light);
            }

            /* --- WIDE IMAGE SECTION --- */
            .wide-map-placeholder {
                width: 100%;
                height: 400px;
                border-radius: 2rem;
                object-fit: cover;
                margin-bottom: 6rem;
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            }

            @media (max-width: 900px) {
                .contact-hero {
                    flex-direction: column;
                    text-align: center;
                    padding-top: 160px;
                    gap: 4rem;
                }
                .hero-vertical-text {
                    display: none;
                }
                .hero-images {
                    height: 400px;
                }
                .contact-grid {
                    grid-template-columns: repeat(2, 1fr);
                }
            }

            @media (max-width: 600px) {
                .hero-text h1 {
                    font-size: 3rem;
                }
                .contact-grid {
                    grid-template-columns: 1fr;
                    gap: 3rem;
                }
                .hero-images {
                    height: 350px;
                }
                .hero-img-1, .hero-img-2 {
                    position: static;
                    width: 100%;
                    height: auto;
                    aspect-ratio: 4/3;
                }
                .hero-images {
                    flex-direction: column;
                    gap: 1.5rem;
                    height: auto;
                }
                .wide-map-placeholder {
                    height: 250px;
                    border-radius: 1.5rem;
                }
            }
        </style>
    </head>
    <body>
        <Header isOverlay={true} lightOverlay={true} translatedPaths={translatedPaths} />

        <main>
            {isFallback && <ContentFallback availableIn="es" fallbackPath="/contacto" />}
            
            <section class="contact-hero">
                <div class="hero-vertical-text">CONTACTO</div>
                <div class="hero-text">
                    <h1>Contacto</h1>
                    <p>Estamos siempre encantados de ayudarte. Hablemos de tu próximo viaje.</p>
                </div>
                <!-- Images matching the newly provided original Contact UI design -->
                <div class="hero-images">
                    <img src="https://picsum.photos/400/500?random=11" alt="Meeting placeholder" class="hero-img hero-img-1" />
                    <img src="https://picsum.photos/500/600?random=12" alt="Working placeholder" class="hero-img hero-img-2" />
                </div>
            </section>

            <section class="icon-grid-section">
                <h2>¿Cómo podemos ayudarte?</h2>
                
                <div class="contact-grid">
                    <a href="tel:958669016" class="contact-item">
                        <div class="icon-circle"><i class="fa-solid fa-phone"></i></div>
                        <h3>Teléfono</h3>
                        <p>958 66 90 16</p>
                    </a>
                    
                    <a href="https://wa.me/34653880210" target="_blank" class="contact-item">
                        <div class="icon-circle"><i class="fa-brands fa-whatsapp"></i></div>
                        <h3>WhatsApp</h3>
                        <p>653 88 02 10</p>
                    </a>
                    
                    <a href="mailto:guadix@viajesveleta.es" class="contact-item">
                        <div class="icon-circle"><i class="fa-solid fa-envelope"></i></div>
                        <h3>Correo electrónico</h3>
                        <p>guadix@viajesveleta.es</p>
                    </a>

                    <a href="https://www.google.com/maps/search/?api=1&query=Viajes+Veleta,+Calle+Poetisa+Hafsa,+3,+Guadix" target="_blank" class="contact-item">
                        <div class="icon-circle"><i class="fa-solid fa-location-dot"></i></div>
                        <h3>Dirección física</h3>
                        <p>Poetisa Hafsa, nº 3<br/>Guadix (Granada)</p>
                    </a>

                    <a href="https://instagram.com/viajesveletaguadix" target="_blank" class="contact-item">
                        <div class="icon-circle"><i class="fa-brands fa-instagram"></i></div>
                        <h3>Instagram</h3>
                        <p>@viajesveletaguadix</p>
                    </a>

                    <a href="https://www.facebook.com/people/Viajes-Veleta/61564838170871/" target="_blank" class="contact-item">
                        <div class="icon-circle"><i class="fa-brands fa-facebook-f"></i></div>
                        <h3>Facebook</h3>
                        <p>Viajes Veleta</p>
                    </a>
                </div>
            </section>

            <!-- Mapa incrustado clásico (NO requiere API Key) -->
            <iframe 
                src="https://maps.google.com/maps?hl=es&q=Viajes%20Veleta,%20Calle%20Poetisa%20Hafsa,%203,%20Guadix&ie=UTF8&t=&z=16&iwloc=B&output=embed" 
                class="wide-map-placeholder" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                title="Ubicación de Viajes Veleta en Guadix"
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>

        </main>

        <Footer />
    </body>
</html>l>
