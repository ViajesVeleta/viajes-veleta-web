---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import {
	getLangFromUrl,
	useTranslations,
	useTranslatedPath,
} from "../i18n/utils";
import { getDynamicImage } from "../utils/images";
import {
	getPostNavigation,
	getRelatedPosts,
	getPostUrl,
} from "../utils/postUtils";

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	translatedPaths,
	id,
	collection,
} = Astro.props;

const resolvedHeroImage =
	typeof heroImage === "string" ? getDynamicImage(heroImage) : heroImage;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

let nextPost: any = null;
let prevPost: any = null;
let relatedPosts: any[] = [];

if (collection && id) {
	const nav = await getPostNavigation(collection, id, lang);
	nextPost = nav.nextPost;
	prevPost = nav.prevPost;

	const mockPost = { id, data: { tags } } as any;
	relatedPosts = await getRelatedPosts(collection, mockPost, lang, 3);
}

const isEs = lang === "es";
const prevLabel = isEs ? "ENTRADA ANTERIOR" : "PREVIOUS ENTRY";
const nextLabel = isEs ? "ENTRADA SIGUIENTE" : "NEXT ENTRY";
const relatedLabel = isEs ? "Entradas relacionadas" : "Related entries";
---

<html lang={lang} dir="ltr">
	<head>
		<BaseHead
			title={title}
			description={description}
			translatedPaths={translatedPaths}
			image={resolvedHeroImage}
		/>
		<style>
			main {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				height: 60vh;
				position: relative;
				margin-bottom: 2rem;
			}
			.hero-image::before {
				content: "";
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: rgba(0, 0, 0, 0.5);
				z-index: 1;
			}
			.hero-image::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 15rem;
				background: linear-gradient(
					to top,
					var(--bg-primary),
					transparent
				);
				z-index: 1;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				box-shadow: none;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--on-surface);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 3rem;
				font-weight: 800;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--on-surface-variant);
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				margin-bottom: 2rem;
			}
			.tag {
				background: var(--surface-variant);
				color: var(--on-surface-variant);
				padding: 0.25rem 0.75rem;
				border-radius: 50px;
				font-size: 0.85rem;
				text-decoration: none;
				transition: all 0.2s ease;
			}
			.tag:hover {
				background: var(--primary);
				color: var(--on-primary);
			}
			.post-navigation-wrapper {
				max-width: 1000px;
				margin: 4rem auto;
				padding: 0 1rem;
			}
			.post-navigation {
				display: flex;
				justify-content: space-between;
			}
			.nav-link {
				display: flex;
				align-items: center;
				gap: 1rem;
				text-decoration: none;
				color: var(--on-surface);
				max-width: 45%;
				transition: color 0.2s ease;
			}
			.nav-link:hover {
				color: var(--primary);
			}
			.nav-link.next {
				text-align: right;
				flex-direction: row-reverse;
				margin-left: auto;
			}
			.nav-content {
				display: flex;
				flex-direction: column;
			}
			.nav-label {
				font-size: 0.8rem;
				color: var(--on-surface-variant);
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 0.25rem;
			}
			.nav-title {
				font-size: 1.1rem;
				font-weight: 400;
			}
			.nav-chevron {
				color: var(--on-surface-variant);
				width: 32px;
				height: 32px;
				opacity: 0.5;
			}

			.related-posts {
				background: var(--surface-container-low);
				padding: 4rem 1rem;
				margin-top: 4rem;
			}
			.related-posts-inner {
				max-width: 1000px;
				margin: auto;
			}
			.related-posts h2 {
				font-size: 1.8rem;
				font-weight: 300;
				margin-bottom: 2rem;
				color: var(--on-surface);
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 2rem;
			}
			.related-card {
				text-decoration: none;
				color: var(--on-surface);
				transition: transform 0.2s ease;
			}
			.related-card:hover {
				transform: translateY(-5px);
			}
			.related-img {
				width: 100%;
				aspect-ratio: 16/10;
				object-fit: cover;
				margin-bottom: 1rem;
				display: block;
			}
			.related-card h3 {
				font-size: 1.1rem;
				font-weight: 400;
				margin: 0 0 0.5rem 0;
			}
			.related-card time {
				font-size: 0.9rem;
				color: var(--on-surface-variant);
			}
		</style>
	</head>

	<body>
		<Header isOverlay={true} translatedPaths={translatedPaths} />
		<main>
			<article>
				<div class="hero-image">
					{
						resolvedHeroImage && (
							<Image
								width={1920}
								height={1080}
								src={resolvedHeroImage}
								alt=""
								loading="eager"
								fetchpriority="high"
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} locale={lang} />
							{
								updatedDate && (
									<div class="last-updated-on">
										{t("blog.lastUpdated")}{" "}
										<FormattedDate
											date={updatedDate}
											locale={lang}
										/>
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							tags && tags.length > 0 && (
								<div class="tags">
									{tags.map((tag: string) => (
										<a
											href={translatePath(
												`/tags/${tag}/`,
											)}
											class="tag"
										>
											#{tag}
										</a>
									))}
								</div>
							)
						}
						<hr />
					</div>
					<slot />
				</div>

				{
					collection && id && (
						<div class="post-footer">
							{(prevPost || nextPost) && (
								<div class="post-navigation-wrapper">
									<div class="post-navigation">
										{prevPost ? (
											<a
												href={getPostUrl(
													collection,
													prevPost.id,
												)}
												class="nav-link prev"
											>
												<svg
													width="24"
													height="24"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
													class="nav-chevron"
												>
													<path d="M15 18l-6-6 6-6" />
												</svg>
												<div class="nav-content">
													<span class="nav-label">
														{prevLabel}
													</span>
													<span class="nav-title">
														{prevPost.data.title}
													</span>
												</div>
											</a>
										) : (
											<div />
										)}

										{nextPost ? (
											<a
												href={getPostUrl(
													collection,
													nextPost.id,
												)}
												class="nav-link next"
											>
												<svg
													width="24"
													height="24"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
													class="nav-chevron"
												>
													<path d="M9 18l6-6-6-6" />
												</svg>
												<div class="nav-content">
													<span class="nav-label">
														{nextLabel}
													</span>
													<span class="nav-title">
														{nextPost.data.title}
													</span>
												</div>
											</a>
										) : (
											<div />
										)}
									</div>
								</div>
							)}

							{relatedPosts.length > 0 && (
								<div class="related-posts">
									<div class="related-posts-inner">
										<h2>{relatedLabel}</h2>
										<div class="related-grid">
											{relatedPosts.map((p: any) => {
												const pImage =
													typeof p.data.heroImage ===
													"string"
														? getDynamicImage(
																p.data
																	.heroImage,
															)
														: p.data.heroImage;
												return (
													<a
														href={getPostUrl(
															collection,
															p.id,
														)}
														class="related-card"
													>
														{pImage && (
															<Image
																src={pImage}
																alt={
																	p.data.title
																}
																width={400}
																height={250}
																class="related-img"
															/>
														)}
														<h3>{p.data.title}</h3>
														<time
															datetime={p.data.pubDate.toISOString()}
														>
															<FormattedDate
																date={
																	p.data
																		.pubDate
																}
																locale={lang}
															/>
														</time>
													</a>
												);
											})}
										</div>
									</div>
								</div>
							)}
						</div>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>
