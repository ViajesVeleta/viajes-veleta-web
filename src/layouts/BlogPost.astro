---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import {
	getLangFromUrl,
	useTranslations,
	useTranslatedPath,
} from "../i18n/utils";
import { getDynamicImage } from "../utils/images";
import {
	getPostNavigation,
	getRelatedPosts,
	getPostUrl,
} from "../utils/postUtils";

const {
	title,
	description,
	date,
	updatedDate,
	image,
	location,
	tags,
	translatedPaths,
	id,
	collection,
} = Astro.props;

const resolvedImage =
	typeof image === "string" ? getDynamicImage(image) : image;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

let nextPost: any = null;
let prevPost: any = null;
let relatedPosts: any[] = [];

if (collection && id) {
	const nav = await getPostNavigation(collection, id, lang);
	nextPost = nav.nextPost;
	prevPost = nav.prevPost;

	const mockPost = { id, data: { tags } } as any;
	relatedPosts = await getRelatedPosts(collection, mockPost, lang, 3);
}

const isEs = lang === "es";
const isGroups = collection === "groups";

const prevLabel = isEs
	? isGroups
		? "VIAJE ANTERIOR"
		: "ENTRADA ANTERIOR"
	: isGroups
		? "PREVIOUS TRIP"
		: "PREVIOUS ENTRY";

const nextLabel = isEs
	? isGroups
		? "VIAJE SIGUIENTE"
		: "ENTRADA SIGUIENTE"
	: isGroups
		? "NEXT TRIP"
		: "NEXT ENTRY";

const relatedLabel = isEs
	? isGroups
		? "Otros viajes en grupo"
		: "Entradas relacionadas"
	: isGroups
		? "Other group trips"
		: "Related entries";
---

<html lang={lang} dir="ltr">
	<head>
		<BaseHead
			title={title}
			description={description}
			translatedPaths={translatedPaths}
			image={resolvedImage}
		/>
		<style>
			main {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				height: 45vh;
				position: relative;
				margin-bottom: 0;
				display: flex;
				align-items: flex-end;
				justify-content: center;
				overflow: hidden;
				padding-bottom: 7rem;
			}
			.hero-image::before {
				content: "";
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: linear-gradient(
					to bottom,
					rgba(0, 0, 0, 0.3),
					rgba(0, 0, 0, 0.6)
				);
				z-index: 1;
			}
			.hero-image img {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				z-index: 0;
			}
			.hero-content {
				position: relative;
				z-index: 2;
				text-align: center;
				color: white;
				width: 90%;
				max-width: 1200px;
				padding-bottom: 0;
			}
			@media (max-width: 768px) {
				.hero-image {
					height: 45vh;
					padding-bottom: 1.5rem !important;
				}
				.hero-content {
					padding-top: 60px;
				}
				.hero-content h1 {
					font-size: 1.6rem !important;
					line-height: 1.2;
					margin-bottom: 0.75rem;
				}
				.hero-content .date {
					font-size: 0.8rem;
					margin-bottom: 0.25rem;
				}
				.hero-content .location {
					font-size: 0.85rem;
					margin-bottom: 1rem;
				}
				.hero-content .tags {
					gap: 0.5rem;
				}
				.hero-content .tag {
					padding: 0.2rem 0.6rem !important;
					font-size: 0.75rem !important;
				}
			}
			.hero-content h1 {
				margin: 0.5rem 0 1.5rem 0;
				font-size: clamp(1.8rem, 6vw, 2.8rem);
				font-weight: 800;
				color: white;
				line-height: 1.1;
				text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
			}
			.hero-content .date {
				margin-bottom: 0.5rem;
				color: rgba(255, 255, 255, 0.9);
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}
			.hero-content .location {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				color: rgba(255, 255, 255, 0.9);
				margin-bottom: 2rem;
				font-size: 1.1rem;
			}
			.hero-content .location-icon {
				opacity: 0.9;
				transform: translateY(-1px);
			}
			.hero-content .tags {
				display: flex;
				gap: 0.75rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.hero-content .tag {
				background: rgba(255, 255, 255, 0.15);
				color: white;
				padding: 0.4rem 1rem;
				border-radius: 50px;
				font-size: 0.9rem;
				text-decoration: none;
				transition: all 0.3s ease;
				backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.1);
			}
			.hero-content .tag:hover {
				background: white;
				color: var(--primary);
				transform: translateY(-2px);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto 3rem auto;
				padding: 1em;
				color: var(--on-surface);
			}
			.prose > :first-child {
				margin-top: 0 !important;
				padding-top: 0 !important;
			}
			@media (max-width: 768px) {
				.prose {
					margin-top: -2.5rem !important;
					padding-top: 0 !important;
				}
			}
			.prose.prose-wide {
				width: 1080px;
			}

			.post-navigation-wrapper {
				max-width: 1000px;
				margin: 4rem auto;
				padding: 0 1rem;
			}
			.post-navigation {
				display: flex;
				justify-content: space-between;
			}
			.nav-link {
				display: flex;
				align-items: center;
				gap: 1rem;
				text-decoration: none;
				color: var(--on-surface);
				max-width: 45%;
				transition: color 0.2s ease;
			}
			.nav-link:hover {
				color: var(--primary);
			}
			.nav-link.next {
				text-align: right;
				flex-direction: row-reverse;
				margin-left: auto;
			}
			.nav-content {
				display: flex;
				flex-direction: column;
			}
			.nav-label {
				font-size: 0.8rem;
				color: var(--on-surface-variant);
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 0.25rem;
			}
			.nav-title {
				font-size: 1.1rem;
				font-weight: 400;
			}
			.nav-chevron {
				color: var(--on-surface-variant);
				width: 32px;
				height: 32px;
				opacity: 0.5;
			}

			.related-posts {
				background: var(--surface-container-low);
				padding: 4rem 1rem;
				margin-top: 4rem;
			}
			.related-posts-inner {
				max-width: 1000px;
				margin: auto;
			}
			.related-posts h2 {
				font-size: 1.8rem;
				font-weight: 300;
				margin-bottom: 2rem;
				color: var(--on-surface);
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 2rem;
			}
			.related-card {
				text-decoration: none;
				color: var(--on-surface);
				transition: transform 0.2s ease;
			}
			.related-card:hover {
				transform: translateY(-5px);
			}
			.related-img {
				width: 100%;
				aspect-ratio: 16/10;
				object-fit: cover;
				margin-bottom: 1rem;
				display: block;
			}
			.related-card h3 {
				font-size: 1.1rem;
				font-weight: 400;
				margin: 0 0 0.5rem 0;
			}
			.related-card time {
				font-size: 0.9rem;
				color: var(--on-surface-variant);
			}
		</style>
	</head>

	<body>
		<Header isOverlay={true} translatedPaths={translatedPaths} />
		<main>
			<article>
				<div class="hero-image">
					{
						resolvedImage && (
							<Image
								width={1920}
								height={1080}
								src={resolvedImage}
								alt=""
								loading="eager"
								fetchpriority="high"
							/>
						)
					}
					<div class="hero-content">
						<div class="date">
							<FormattedDate date={date} locale={lang} />
							{
								updatedDate && (
									<div class="last-updated-on">
										{t("blog.lastUpdated")}{" "}
										<FormattedDate
											date={updatedDate}
											locale={lang}
										/>
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							location && location.length > 0 && (
								<div class="location">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="16"
										height="16"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										class="location-icon"
									>
										<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
										<circle cx="12" cy="10" r="3" />
									</svg>
									<span>
										{location.join(
											"\u00A0\u00A0\u00A0•\u00A0\u00A0\u00A0",
										)}
									</span>
								</div>
							)
						}
						{
							tags && tags.length > 0 && (
								<div class="tags">
									{tags.map((tag: string) => (
										<a
											href={translatePath(
												`/tags/${tag}/`,
											)}
											class="tag"
										>
											#{tag}
										</a>
									))}
								</div>
							)
						}
					</div>
				</div>
				<div
					class={`prose ${collection === "groups" ? "prose-wide" : ""}`}
				>
					<slot />
				</div>

				{
					collection && id && (
						<div class="post-footer">
							{(prevPost || nextPost) && (
								<div class="post-navigation-wrapper">
									<div class="post-navigation">
										{prevPost ? (
											<a
												href={getPostUrl(
													collection,
													prevPost.id,
												)}
												class="nav-link prev"
											>
												<svg
													width="24"
													height="24"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
													class="nav-chevron"
												>
													<path d="M15 18l-6-6 6-6" />
												</svg>
												<div class="nav-content">
													<span class="nav-label">
														{prevLabel}
													</span>
													<span class="nav-title">
														{prevPost.data.title}
													</span>
												</div>
											</a>
										) : (
											<div />
										)}

										{nextPost ? (
											<a
												href={getPostUrl(
													collection,
													nextPost.id,
												)}
												class="nav-link next"
											>
												<svg
													width="24"
													height="24"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
													class="nav-chevron"
												>
													<path d="M9 18l6-6-6-6" />
												</svg>
												<div class="nav-content">
													<span class="nav-label">
														{nextLabel}
													</span>
													<span class="nav-title">
														{nextPost.data.title}
													</span>
												</div>
											</a>
										) : (
											<div />
										)}
									</div>
								</div>
							)}

							{relatedPosts.length > 0 && (
								<div class="related-posts">
									<div class="related-posts-inner">
										<h2>{relatedLabel}</h2>
										<div class="related-grid">
											{relatedPosts.map((p: any) => {
												const pImage =
													typeof p.data.image ===
													"string"
														? getDynamicImage(
																p.data.image,
															)
														: p.data.image;
												return (
													<a
														href={getPostUrl(
															collection,
															p.id,
														)}
														class="related-card"
													>
														{pImage && (
															<Image
																src={pImage}
																alt={
																	p.data.title
																}
																width={400}
																height={250}
																class="related-img"
															/>
														)}
														<h3>{p.data.title}</h3>
														<time
															datetime={p.data.date.toISOString()}
														>
															<FormattedDate
																date={
																	p.data.date
																}
																locale={lang}
															/>
														</time>
													</a>
												);
											})}
										</div>
									</div>
								</div>
							)}
						</div>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>
